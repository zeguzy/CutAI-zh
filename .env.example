# ============================================================
# CutAI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For local development, defaults work out of the box.

# --- Provider Switches ---
# LLM_PROVIDER: "local" (Ollama/Qwen) or "groq" (Groq cloud API)
LLM_PROVIDER=local
# IMAGE_PROVIDER: "local" (SD 1.5 on GPU) or "replicate" (SDXL cloud API)
IMAGE_PROVIDER=local

# --- Groq (only needed if LLM_PROVIDER=groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# --- Replicate (only needed if IMAGE_PROVIDER=replicate) ---
REPLICATE_API_TOKEN=

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:3b
LLM_NUM_CTX=4096
LLM_TEMPERATURE=0.7

# --- Server ---
PORT=8000

# --- Database ---
# DATABASE_URL=sqlite+aiosqlite:///./cutai.db

# --- CORS ---
# Comma-separated additional origins (production domains)
# CORS_ORIGINS=https://cutai.vercel.app,https://cutai.onrender.com

# --- Frontend (set in Vercel dashboard or .env.local) ---
# VITE_API_URL=https://your-backend.onrender.com
